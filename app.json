{
  "expo": {
    "name": "batchguard",
    "slug": "batchguard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "batchguard",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.zubipon321.batchguard"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-audio",
      [
"@config-plugins/react-native-webrtc",
    {
      "cameraPermission": "Cho phép ứng dụng sử dụng Camera để theo dõi và phân tích",
      "microphonePermission": "Cho phép ứng dụng sử dụng Micro để thu âm"
    }
  ],
     [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ] 
     
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d63440fa-b6cb-4124-bfed-a2fda548ebcd"
      }
    }
  }
}
